# ============================================================
#  依赖 / 运行时 —— 绝不提交
# ============================================================
node_modules/

# 运行时数据（含账号凭证、ZCode登录态备份，绝不提交）
data/

# ============================================================
#  开发版 / 注册机（私有，不开源）
# ============================================================
# dev/ 整个目录含注册机 register-ipc.js —— 客户版不需要，一律排除
dev/
# 开发版打包配置（描述注册机构建流程）
build-dev.yml

# build/ 中含服务器 IP/部署脚本/内部下载页，不开源
build/deploy-server.js
build/dl-index.html

# ============================================================
#  构建产物
# ============================================================
dist/
out/

# build/ 目录含 electron-builder 构建脚本（gen-icon.js/after-pack.js），需跟踪
# （覆盖上面可能的 build/ 通配规则）
!build/
!build/**

# 图标中间产物（保留最终 icon.ico/icon.svg，排除 PNG 临时件）
assets/icon-256.png

# ============================================================
#  杂项
# ============================================================
# 日志
*.log

